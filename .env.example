# =============================================================================
# Shopify Order Download — environment configuration
# Copy to `.env` on the EC2 box and fill in real values.
# =============================================================================

# -- Shopify Admin GraphQL credentials ----------------------------------------
# SHOPIFY_SHOP is the *.myshopify.com handle (without the protocol).
# Example: acme-store.myshopify.com
SHOPIFY_SHOP=your-shop.myshopify.com

# Custom App admin access token. Create via:
#   Shopify Admin > Settings > Apps and sales channels > Develop apps
#     > Create an app > Configure Admin API scopes (read_orders, read_customers)
#     > Install app > reveal the Admin API access token (starts with `shpat_`)
SHOPIFY_ACCESS_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Shopify Admin API version (use the latest stable; bump quarterly).
SHOPIFY_API_VERSION=2025-01

# -- Date window for the historical backfill ----------------------------------
# Leave SHOPIFY_START_DATE empty to fetch from the shop's first ever order.
# Both dates are inclusive, ISO-8601 (UTC).
SHOPIFY_START_DATE=
SHOPIFY_END_DATE=2026-07-31T23:59:59Z

# How many orders to ask for per page (Shopify cap = 250).
SHOPIFY_PAGE_SIZE=250

# Cost-bucket safety margin. We pause when remaining cost-points drops below
# (last actual cost * this multiplier). Higher = safer / slower.
SHOPIFY_COST_SAFETY_MULTIPLIER=2.0

# -- Postgres (RDS) -----------------------------------------------------------
# Point this at your RDS endpoint when running on EC2. For local docker-compose
# the bundled `postgres` service is used automatically (see docker-compose.yml).
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=shopify_orders
POSTGRES_USER=shopify
POSTGRES_PASSWORD=change_me_in_prod
POSTGRES_SSLMODE=disable        # set to `require` for RDS

# -- Redis --------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0

# -- Excel export -------------------------------------------------------------
# Maximum rows per .xlsx file. The user requirement is 1 lakh = 100000.
EXCEL_ROWS_PER_FILE=100000

# Where exported files are written inside the container (mounted volume).
EXPORT_DIR=/data/exports

# -- API ----------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000

# -- Logging ------------------------------------------------------------------
LOG_LEVEL=INFO
