# =============================================================================
# Shopify Order Download — environment template.
# Copy to `.env` (dev) or `.env.prod` (EC2) and fill in real values.
# =============================================================================

# -- Shopify Configuration ----------------------------------------------------
# *.myshopify.com handle, no protocol. e.g. acme-store.myshopify.com
SHOPIFY_STORE_URL=your-shop.myshopify.com

# REQUIRED. Admin GraphQL access token (`shpat_...`).
# Create via Shopify Admin → Settings → Apps and sales channels →
#   Develop apps → Create app → Configure Admin API scopes
#     (read_orders, read_all_orders, read_customers) →
#   Install app → reveal the Admin API access token.
SHOPIFY_ACCESS_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Shopify App API key + secret. Optional unless you wire up webhooks
# (the API secret signs Shopify webhook HMACs).
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=

# Shopify Admin API version. Bump quarterly.
SHOPIFY_API_VERSION=2025-01

# HTTP client timeout for each Shopify call.
SHOPIFY_HTTP_TIMEOUT_SEC=30

# Substituted when an order's email is null.
CUSTOMER_DUMMY_EMAIL=noemail@customer.internal

# -- Backfill window ----------------------------------------------------------
# Empty start → fetch from the shop's very first order.
SHOPIFY_START_DATE=
SHOPIFY_END_DATE=2026-07-31T23:59:59Z

SHOPIFY_PAGE_SIZE=250
# Bigger value = bigger safety margin against the Shopify cost bucket.
SHOPIFY_COST_SAFETY_MULTIPLIER=2.0

# -- Postgres (RDS in prod, local container in dev) --------------------------
# -- Postgres (RDS) -----------------------------------------------------------
# Point this at your RDS endpoint when running on EC2. For local docker-compose
# the bundled `postgres` service is used automatically (see docker-compose.yml).
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=shopify_orders
POSTGRES_USER=shopify
POSTGRES_PASSWORD=change_me_in_prod
POSTGRES_SSLMODE=disable        # set to `require` for RDS

# -- Redis --------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0

# -- Excel export -------------------------------------------------------------
# 1 lakh per file: 80k → 1 file, 1,10,000 → 2 files (1,00,000 + 10,000).
EXCEL_ROWS_PER_FILE=100000
EXPORT_DIR=/data/exports

# -- API ----------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO
